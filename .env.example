# --- Required: AI ---
ANTHROPIC_API_KEY=sk-ant-...

# --- Required: internal control-plane DB (audit log + agents + databases + encrypted creds) ---
# Railway provisions this — set DATABASE_URL automatically.
DATABASE_URL=postgresql://user:pass@host:5432/queryshield

# --- Required: vault encryption key (Fernet) ---
# Generate once with:  python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# If this changes, all stored connection strings become unreadable.
VAULT_KEY=

# --- Optional: cache ---
# If unset, cache falls back to in-memory dict (fine for single-instance deploys).
REDIS_URL=

# --- Billing (Stripe) ---
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_ENTERPRISE=price_...

# --- Notifications ---
SENDGRID_API_KEY=SG....
SENDGRID_FROM=alerts@queryshield.io
# Product-specific Discord webhook — separate channel from other agentic-build products.
QUERY_SHIELD_DISCORD_WEBHOOK_URL=

# --- Runtime ---
PORT=8000
ENVIRONMENT=production
LOG_LEVEL=INFO
MAX_ROWS_HARD_LIMIT=5000
PUBLIC_BASE_URL=https://api.queryshield.io
